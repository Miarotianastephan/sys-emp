        "response": {
            "success": true,
            "message": "Compte créé avec succès",
            "data": {
                "estActif": true,
                "id": 1,
                "nom": "Rakoto",
                "prenom": "Jean",
                "email": "jean@societe.mg",
                "dateEmbauche": "2026-01-01",
                "idRang": 1,
                "updatedAt": "2026-05-04T13:30:52.626Z",
                "createdAt": "2026-05-04T13:30:52.626Z"
            }
        }
      },
      "profile": {
        "method": "GET",
        "url": "/auth/profile",
        "description": "Récupérer le profil utilisateur connecté",
        "headers": {
          "Authorization": "Bearer jwt_token"
        },
        "response": {"lavabe" : "lavabe"}
      }
