        "method": "PUT",
        "url": "/notifications/:id/lu",
        "description": "Marquer une notification comme lue (met aussi à jour vueParValidateur si c'est une absence)",
        "headers": {
          "Authorization": "Bearer jwt_token"
        },
        "response": {
          "success": true,
          "message": "Notification marquée comme lue",
          "data": {
            "id": 1,
            "isLu": true,
            "updatedAt": "2026-05-09T10:05:00.000Z"
