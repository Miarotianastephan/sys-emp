                        "VOIR_EQUIPE_PROPRE",
                        "VOIR_SALAIRES",
                        "VOIR_SES_DONNEES",
                        "VOIR_STATS_GLOBALES"
                    ]
                }
            }
        }
      },
      "register": {
        "method": "POST",
        "url": "/auth/register",
        "description": "Inscription nouvel utilisateur",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
            "nom": "Rakoto",
            "prenom": "Jean",
            "email": "jean@societe.mg",
            "motDePasse": "motdepasse123",
            "dateEmbauche": "2026-01-01",
            "idRang": 1
