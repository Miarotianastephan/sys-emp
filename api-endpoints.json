    "notifications": {
      "subscribe": {
        "method": "GET",
        "url": "/notifications/subscribe",
        "description": "Souscrire au flux de notifications temps réel (SSE)",
        "headers": {
          "Authorization": "Bearer jwt_token"
        },
        "response": {
          "description": "Flux Server-Sent Events avec les notifications",
          "format": "data: {JSON}\n\n",
          "example": "data: {\"id\":1,\"title\":\"Nouvelle demande\",\"message\":\"...\",\"isLu\":false,\"createdAt\":\"2026-05-09T10:00:00.000Z\"}\n\n"
        }
      },
      "lister": {
        "method": "GET",
        "url": "/notifications",
        "description": "Récupérer la liste des notifications de l'utilisateur",
        "headers": {
          "Authorization": "Bearer jwt_token"
        },
        "response": {
          "success": true,
          "data": [
            {
              "id": 1,
              "idUser": 1,
              "type": "INFO",
              "title": "Nouvelle demande d'absence",
