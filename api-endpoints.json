      "login": {
        "method": "POST",
        "url": "/auth/login",
        "description": "Authentification utilisateur",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
            "email": "jean@societe.mg",
            "motDePasse": "motdepasse123"
        },
        "response": {
            "success": true,
            "message": "Connexion réussie",
            "data": {
                "token": "token",
                "user": {
                    "id": 1,
                    "nom": "Rakoto",
                    "prenom": "Jean",
