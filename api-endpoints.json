    "auth": {
      "login": {
        "method": "POST",
        "url": "/auth/login",
        "description": "Authentification utilisateur",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
            "email": "jean@societe.mg",
            "motDePasse": "motdepasse123"
        },
        "response": {
            "success": true,
            "message": "Connexion réussie",
            "data": {
                "token": "token",
                "user": {
                    "id": 1,
                    "nom": "Rakoto",
                    "prenom": "Jean",
                    "email": "jean@societe.mg",
                    "rang": {
                        "id": 1,
                        "niveau": 1,
                        "libelle": "Manager général"
                    },
                    "poste": null,
                    "permissions": [
                        "CREER_TACHE",
                        "GERER_BONUS_PENALITE",
                        "GERER_UTILISATEURS",
                        "POINTER_PRESENCE",
                        "SOUMETTRE_DEMANDE",
