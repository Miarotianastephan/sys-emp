{
  "name": "sys-emp",
  "version": "1.0.0",
  "description": "backend emp sys ",
  "license": "ISC",
  "author": "panda",
  "main": "server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:create": "node src/database/ensure-db.js",
    "db:migrate": "npx sequelize db:migrate",
    "db:seed": "npx sequelize db:seed:all",
    "db:setup": "node src/database/ensure-db.js && npx sequelize db:migrate && npx sequelize db:seed:all",
    "db:reset": "node src/database/ensure-db.js && npx sequelize db:migrate:undo:all && npx sequelize db:migrate && npx sequelize db:seed:all",
    "test": "jest --runInBand --forceExit",
    "test:verbose": "jest --runInBand --forceExit --verbose",
    "test:auth": "jest --runInBand --forceExit --testPathPatterns=auth",
    "test:presence": "jest --runInBand --forceExit --testPathPatterns=presence",
    "test:absence": "jest --runInBand --forceExit --testPathPatterns=absence",
    "test:ferier": "jest --runInBand --forceExit --testPathPatterns=ferier",
    "test:tasks": "jest --runInBand --forceExit --testPathPatterns=tasks",
    "test:bonus": "jest --runInBand --forceExit --testPathPatterns=bonus",
    "test:flow": "jest --runInBand --forceExit --testPathPattern=flow"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "testTimeout": 30000
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "mysql2": "^3.22.3",
    "sequelize": "^3.30.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.5",
    "supertest": "^7.2.2"
  }
}
